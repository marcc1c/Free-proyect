<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="interfaz.MenuInicial">
  <grid id="27dc6" binding="panelMenuInicial" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="403"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="61e9d" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="0" vgap="20">
        <margin top="20" left="20" bottom="20" right="20"/>
        <constraints border-constraint="West"/>
        <properties>
          <focusTraversalPolicyProvider value="false"/>
          <preferredSize width="300" height="150"/>
        </properties>
        <border type="none">
          <title-color color="-2104859"/>
        </border>
        <children>
          <component id="e041d" class="javax.swing.JButton" binding="botonInventario">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-16526340"/>
              <text value="Inventario"/>
            </properties>
          </component>
          <component id="7a960" class="javax.swing.JButton" binding="botonCampoBatalla">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-9076091"/>
              <text value="Campo de batalla"/>
            </properties>
          </component>
          <component id="17706" class="javax.swing.JButton" binding="botonSalir">
            <constraints>
              <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-9076091"/>
              <text value="Salir"/>
            </properties>
          </component>
          <component id="e0e8f" class="javax.swing.JButton" binding="botonInvocar">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-16526340"/>
              <hideActionText value="false"/>
              <text value="Invocar"/>
            </properties>
          </component>
          <component id="f6109" class="javax.swing.JButton" binding="botonLogros">
            <constraints>
              <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-9076091"/>
              <text value="Logros"/>
            </properties>
          </component>
          <component id="7676d" class="javax.swing.JButton" binding="botonTrascender">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-9076091"/>
              <text value="Trascender"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="85fe4" binding="panelDerecha" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="East"/>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="e7015" binding="scrollInventario">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <grid id="a549d" binding="ventanaInventario" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
                <margin top="0" left="0" bottom="0" right="0"/>
                <constraints/>
                <properties>
                  <preferredSize width="200" height="24"/>
                </properties>
                <border type="none"/>
                <children/>
              </grid>
            </children>
          </scrollpane>
        </children>
      </grid>
    </children>
  </grid>
</form>
